# Database
DATABASE_URL="postgresql://username:password@localhost:5432/incubatorhub"

# App
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="The Incubator Hub <noreply@theincubatorhub.org>"

# Moodle LMS Integration
MOODLE_BASE_URL="https://moodle.theincubatorhub.org"
MOODLE_TOKEN="your-moodle-webservice-token"
MOODLE_WEBHOOK_SECRET="your-webhook-secret-change-in-production"
MOODLE_SSO_SECRET="your-sso-secret-change-in-production"
